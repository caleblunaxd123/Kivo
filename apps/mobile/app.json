{
  "expo": {
    "name": "Kivo",
    "slug": "kivo",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "sdkVersion": "54.0.0",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kivo.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Kivo usa el micrófono para que puedas registrar gastos por voz.",
        "NSCameraUsageDescription": "Kivo usa la cámara para escanear tickets y recibos.",
        "NSPhotoLibraryUsageDescription": "Kivo accede a tu galería para adjuntar fotos de tickets."
      }
    },
    "android": {
      "package": "com.kivo.app",
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      ["expo-router", { "root": "src" }],
      "expo-camera",
      [
        "expo-notifications",
        {
          "color": "#6366F1"
        }
      ],
      "expo-secure-store"
    ],
    "scheme": "kivo",
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
